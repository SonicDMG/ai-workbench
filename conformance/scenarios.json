	{
		"slug": "knowledge-base-crud-basic",
		"description": "Knowledge-base CRUD lifecycle. Workspace POST auto-seeds the default chunking + embedding + LLM services; the KB binds to one of each by id, then we round-trip through GET / list / PATCH / DELETE. Pinned response shape: KB record carries embeddingServiceId / chunkingServiceId / vectorCollection / status.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/embedding-services"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases",
				"body": {
					"name": "research",
					"description": "internal docs",
					"embeddingServiceId": "$2.items.0.embeddingServiceId",
					"chunkingServiceId": "$3.items.0.chunkingServiceId"
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases"
			},
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId",
				"body": { "description": "updated description" }
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/knowledge-bases/$4.knowledgeBaseId"
			}
		]
	},
	{
