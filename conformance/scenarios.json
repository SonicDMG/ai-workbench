	{
		"slug": "chunking-service-crud-lifecycle",
		"description": "Workspace-scoped chunking service CRUD: create explicit (independent of the default seed), list, get, patch, delete. Pins the chunking-service record wire shape including engine/strategy/maxChunkSize and the immutable `chunkingServiceId`. The list step paginates over (default + created) so every runtime that auto-seeds a default service still emits a list envelope with both records.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services",
				"body": {
					"name": "fixed-1024",
					"description": "1024-token splitter",
					"engine": "fixed",
					"strategy": "by-tokens",
					"maxChunkSize": 1024,
					"minChunkSize": 64,
					"chunkUnit": "tokens",
					"overlapSize": 64,
					"overlapUnit": "tokens",
					"preserveStructure": true,
					"language": "en"
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services/$2.chunkingServiceId"
			},
			{
				"method": "PATCH",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services/$2.chunkingServiceId",
				"body": { "description": "1024-token splitter (revised)" }
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services/$2.chunkingServiceId"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/chunking-services/$2.chunkingServiceId"
			}
		]
	},
