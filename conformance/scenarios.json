	{
		"slug": "agent-crud-basic",
		"description": "Agent + conversation CRUD lifecycle WITHOUT triggering chat sends. Workspace POST auto-seeds the default LLM service; we bind an agent to it, open a conversation, and tear down. The GET /agents list step is intentionally omitted because workspace POST also auto-seeds two default agents (Bobby + Maven) whose createdAt timestamps frequently collide at millisecond resolution and sort nondeterministically — the per-agent GET below already pins the wire shape every runtime must produce. Sending messages is excluded from conformance because chat completion depends on the upstream LLM API that's not part of the runtime contract.",
		"steps": [
			{
				"method": "POST",
				"path": "/api/v1/workspaces",
				"body": { "name": "w", "kind": "mock" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/llm-services"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/agents",
				"body": {
					"name": "researcher",
					"description": "internal-docs Q&A",
					"llmServiceId": "$2.items.0.llmServiceId"
				}
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId"
			},
			{
				"method": "POST",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations",
				"body": { "title": "thread one" }
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations"
			},
			{
				"method": "GET",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations/$5.conversationId/messages"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId/conversations/$5.conversationId"
			},
			{
				"method": "DELETE",
				"path": "/api/v1/workspaces/$1.workspaceId/agents/$3.agentId"
			}
		]
	},
	{
