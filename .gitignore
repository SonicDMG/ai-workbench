node_modules/
dist/
coverage/
*.log
.env
.env.*
# `pkill -USR2` writes nginx-style backup files; pin explicitly
# so a misconfigured `!.env.foo` allowlist below can't override it.
.env.save
!.env.example
.DS_Store
.vscode/
.idea/

# Default `npm run dev` config persists the file-backed control
# plane here. Per-developer state, never committed.
.workbench-data/
test-results/
runtimes/typescript/workbench.yaml

# Playwright MCP transcript dumps from local browser-driven test runs.
# Currently only `*.log` rules catch the directory's contents; ignore it
# explicitly so a future non-log artifact (HAR, har.json, screenshots,
# etc.) can't be added by accident.
.playwright-mcp/

# Per-developer compose overrides — `docker-compose.override.yml` is
# auto-merged on top of `docker-compose.yml` when present. See
# `docker-compose.override.yml.example` for the template.
docker-compose.override.yml

# Local-only Claude Code settings (per-developer)
.claude/settings.local.json
.claude/launch.json
# Claude Code worktrees spawned by background sub-agents — these are
# full git clones inside the repo tree; ignore them so they don't
# get accidentally added and so repo-wide tools (biome, etc.) skip
# the nested config they contain.
.claude/worktrees/
