{
	"name": "ai-workbench-runtime-typescript",
	"version": "0.2.1",
	"description": "AI Workbench — TypeScript runtime (default green box). Bundled with the UI.",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "dist/root.js",
	"scripts": {
		"dev": "tsx watch src/root.ts",
		"start": "node dist/root.js",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"conformance:mock": "tsx ../../conformance/mock-astra/server.ts",
		"conformance:regenerate": "tsx scripts/conformance-regenerate.ts",
		"smoke:astra": "tsx scripts/smoke-astra.ts",
		"dump:openapi": "tsx scripts/dump-openapi.ts dist/openapi.json",
		"docs:errors": "tsx scripts/gen-errors-doc.ts",
		"docs:errors:check": "tsx scripts/gen-errors-doc.ts --check"
	},
	"dependencies": {
		"@datastax/astra-db-ts": "^2.2.1",
		"@hono/node-server": "^2.0.4",
		"@hono/zod-openapi": "^1.4.0",
		"@huggingface/inference": "^4.13.18",
		"@langchain/cohere": "^1.0.5",
		"@langchain/core": "^1.1.48",
		"@langchain/openai": "^1.4.7",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.76.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/resources": "^2.7.1",
		"@opentelemetry/sdk-node": "^0.218.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@scalar/hono-api-reference": "^0.10.19",
		"hono": "^4.12.23",
		"jose": "^6.2.3",
		"mammoth": "^1.12.0",
		"pdfjs-dist": "^5.7.284",
		"pino": "^10.3.1",
		"read-excel-file": "^9.0.10",
		"ulid": "^3.0.2",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"pino-pretty": "^13.0.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5",
		"write-excel-file": "^4.0.7"
	},
	"overrides": {
		"uuid": "^14.0.0",
		"picomatch": "^4.0.4",
		"brace-expansion": ">=2.0.3",
		"ip-address": "^10.1.1",
		"fast-uri": "^3.1.2",
		"fast-xml-builder": "^1.1.7",
		"protobufjs": "^8.0.2",
		"langsmith": "^0.6.0"
	}
}
